#!/usr/bin/env bash

#Define module specific tests here
#  each test function should be post fixed with "_test" to be automatically 
#  invoked.

LOG_DIRECTORY="${LOG_DIRECTORY:-.log}"

# Global timeout for API readiness check (in seconds)
API_READINESS_TIMEOUT=10

wait_for_api_ready() {
    local timeout=${1:-$API_READINESS_TIMEOUT}
    local status_url="http://localhost:8888/api/status"
    local elapsed=0
    
    while [ $elapsed -lt $timeout ]; do
        if curl -s --max-time 5 "$status_url" > /dev/null 2>&1; then
            local http_code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 5 "$status_url")
            if [ "$http_code" = "200" ]; then
                return 0
            fi
        fi
        sleep 1
        elapsed=$((elapsed + 1))
    done
    
    return 1
}

01_api_health_check_test() {
    local action=health_check
    local name="API Health Check Test"
    local description="This test validates that the API is responding correctly to basic requests."
    local status=""
    local message=""
    local api_health_output_json_file="${LOG_DIRECTORY}/api_health_check_results.json"
    printf "\n"
    printf "  Test: %s\n" "${name}"
    printf "    Description: %s\n" "${description}"
    printf "      This test aims to answer the following questions: \n"
    printf "        Is the API server responding?\n"
    printf "        Are the basic endpoints accessible?\n"
    printf "        Do the endpoints return valid JSON?\n"
    printf "    Starting API health check...\n"
    make start > /dev/null 2>&1
    
    printf "    Waiting for API to be ready...\n"
    if ! wait_for_api_ready; then
        printf "    Status: $(bold $(red "FAILED")) - API not ready after ${API_READINESS_TIMEOUT} seconds\n"
        make stop > /dev/null 2>&1
        exit 1
    fi
    
    # Test 1: Status endpoint
    printf "    Testing status endpoint...\n"
    status_http_code=$(curl -s --max-time 10 -o /tmp/status_response -w "%{http_code}" http://localhost:8888/api/status)
    status_exit_code=$?
    
    if [ $status_exit_code -ne 0 ]; then
        printf "    Status: $(bold $(red "FAILED")) - Status endpoint failed with exit code $status_exit_code\n"
        make stop > /dev/null 2>&1
        exit 1
    fi
    
    if [ "$status_http_code" != "200" ]; then
        printf "    Status: $(bold $(red "FAILED")) - Status endpoint returned HTTP $status_http_code\n"
        printf "    Response: %s\n" "$(cat /tmp/status_response)"
        make stop > /dev/null 2>&1
        exit 1
    fi
    
    status_result=$(cat /tmp/status_response)
    # Validate status response is valid JSON
    if ! echo "$status_result" | jq . >/dev/null 2>&1; then
        printf "    Status: $(bold $(red "FAILED")) - Status endpoint returned invalid JSON\n"
        printf "    Response: %s\n" "$status_result"
        make stop > /dev/null 2>&1
        exit 1
    fi
    
    # Test 3: Test invalid endpoint returns proper error
    printf "    Testing error handling...\n"
    error_http_code=$(curl -s --max-time 10 -o /dev/null -w "%{http_code}" http://localhost:8888/api/nonexistent)
    error_exit_code=$?
    
    if [ $error_exit_code -ne 0 ]; then
        printf "    Status: $(bold $(red "FAILED")) - Error test failed with exit code $error_exit_code\n"
        make stop > /dev/null 2>&1
        exit 1
    fi
    
    # Check that we get a 404 for non-existent endpoint
    if [ "$error_http_code" != "404" ]; then
        printf "    Status: $(bold $(red "FAILED")) - Expected 404 for non-existent endpoint, got $error_http_code\n"
        make stop > /dev/null 2>&1
        exit 1
    fi
    
    printf "\n"
    printf "    Compiling results...\n"
    
    # Create summary JSON
    health_summary=$(jq -n \
        --arg status_response "$status_result" \
        --arg scenario_response "$scenario_result" \
        --arg status_http_code "$status_http_code" \
        --arg scenario_http_code "$scenario_http_code" \
        --arg error_http_code "$error_http_code" \
        '{
            "test_name": "API Health Check",
            "timestamp": now | strftime("%Y-%m-%d %H:%M:%S"),
            "results": {
                "status_endpoint": {
                    "status": "PASSED",
                    "http_code": $status_http_code,
                    "response": ($status_response | fromjson)
                },
                "scenario_endpoint": {
                    "status": "PASSED", 
                    "http_code": $scenario_http_code,
                    "response_length": ($scenario_response | length)
                },
                "error_handling": {
                    "status": "PASSED",
                    "http_code": $error_http_code
                }
            },
            "overall_status": "PASSED"
        }')
    
    echo "$health_summary" > "$api_health_output_json_file"
    
    # Extract key info for display
    api_version=$(echo "$status_result" | jq -r '.version // "unknown"' 2>/dev/null)
    
    message="        API Health Check Summary:
            Status endpoint: PASSED (HTTP $status_http_code)
            Scenario endpoint: PASSED (HTTP $scenario_http_code)
            Error handling: PASSED (proper 404 response)
            API version: ${api_version}"
    
    status=$(bold $(green "PASSED"))
    printf "    Message:\n%s\n" "$message"
    printf "    %-77s %s\n" "Status:" "${status}"
    make stop > /dev/null 2>&1
    printf "    See the health check log for more info: %s\n" "$api_health_output_json_file"
    
    # Clean up temp files
    rm -f /tmp/status_response /tmp/scenario_response
    exit 0
}

02_simulation_test_scenario_test() {
    local action=simulate
    local name="Simulation Test"
    local description="This test executes the simulation_test.launch.py scenario and verify the model checking results."
    local status=""
    local message=""
    local model_checking_output_json_file="${LOG_DIRECTORY}/simulation_test_model_checking_results.json"
    printf "\n"
    printf "  Test: %s\n" "${name}"
    printf "    Description: %s\n" "${description}"
    printf "      This test aims to answer the following questions: \n"
    printf "        Did the vehicle move?\n"
    printf "        Did the vehicle reach its goal?\n"
    printf "        Did the scenario generate any exceptions?\n"
    printf "    Running scenario...\n"
    make start > /dev/null 2>&1
    
    printf "    Waiting for API to be ready...\n"
    if ! wait_for_api_ready; then
        printf "    Status: $(bold $(red "FAILED")) - API not ready after ${API_READINESS_TIMEOUT} seconds\n"
        make stop > /dev/null 2>&1
        exit 1
    fi
    
    {
        while true; do
            sleep 1
            printf "." >&2
        done
    } &
    dot_pid=$!
    
    result=$(curl -s --max-time 20 -X POST http://localhost:8888/api/scenario/start/model_checked -H "Content-Type: application/json" -d '{}')
    curl_exit_code=$?
    
    kill $dot_pid 2>/dev/null
    wait $dot_pid 2>/dev/null
    
    if [ $curl_exit_code -eq 28 ]; then
        printf "\n"
        printf "    Status: $(bold $(red "FAILED")) - Request timed out after 20 seconds\n"
        make stop > /dev/null 2>&1
        exit 1
    elif [ $curl_exit_code -ne 0 ]; then
        printf "\n"
        printf "    Status: $(bold $(red "FAILED")) - Request failed with exit code $curl_exit_code\n"
        make stop > /dev/null 2>&1
        exit 1
    fi
    
    printf "\n"
    printf "    Parsing results...\n"
    echo "${result}" > "${model_checking_output_json_file}"
    
    # Check if result is empty or null
    if [ -z "$result" ] || [ "$result" = "null" ]; then
        printf "    Status: $(bold $(red "FAILED")) - API returned no results\n"
        make stop > /dev/null 2>&1
        exit 1
    fi
    
    # Check if result is valid JSON
    if ! echo "$result" | jq . >/dev/null 2>&1; then
        printf "    Status: $(bold $(red "FAILED")) - API returned invalid JSON\n"
        printf "    Response: %s\n" "$result"
        make stop > /dev/null 2>&1
        exit 1
    fi
    
    # Check if expected structure exists
    if ! echo "$result" | jq -e '.model_check_result.results.SUMMARY' >/dev/null 2>&1; then
        printf "    Status: $(bold $(red "FAILED")) - API response missing expected model check results\n"
        printf "    Response: %s\n" "$result"
        make stop > /dev/null 2>&1
        exit 1
    fi
    
    message=$(echo "$result" | jq -r '
      .model_check_result.results.SUMMARY as $s |
      (
        "        Model Check Summary: " +
        ($s.analyzed | tostring) + " analyzed, " +
        ($s.passed | tostring) + " passed, " +
        ($s.failed | tostring) + " failed, success rate: " +
        ((($s.success_rate // 0) * 100 | round) | tostring) + "% - Overall result: " +
        ($s.overall_result // "UNKNOWN") +
        "\n"
      ) +
      "            Propositions:\n" +
      (
        .model_check_result.results
        | to_entries
        | map(select(.key != "SUMMARY"))
        | map(
          "                " + .value.description.title + ": " + (.value.status // "UNKNOWN") + "\n" +
          "                    Description: " + (.value.description.description // "N/A") + "\n" +
          "                    Safety Goal: " + (.value.description.safety_rationale // "N/A") + "\n" +
          "                    Formula Description: " + (.value.formula_description // "N/A") + "\n" +
          "                    Formula Type: " + (.value.formula_type // "N/A")
        )
        | join("\n\n")
      )
    ')
    model_checking_status=$(echo "$result" | jq -r '
      if (.model_check_result.results.SUMMARY.success_rate == 1) then 0 else 1 end
    ')
    if [ "$model_checking_status" -eq 0 ]; then
        status=$(bold $(green "PASSED"))
    else
        status=$(bold $(red "FAILED"))
    fi 
    printf "    Message:\n%s\n" "$message"
    printf "    %-77s %s\n" "Status:" "${status}"
    make stop > /dev/null 2>&1
    printf "    See the model checking log for more info: %s\n" "$model_checking_output_json_file"
    exit $model_checking_status
}

#!/usr/bin/env bash

# ros_topic_benchmark_test.sh - Unit tests for ros_topic_benchmark.sh

ros_topic_benchmark_test() {
    local action=benchmark
    local name="ROS Topic Benchmark Test"
    local description="This test executes the ros_topic_benchmark.sh script and verifies message rate performance metrics."
    local status=""
    local message=""
    local benchmark_output_file="${LOG_DIRECTORY}/ros_topic_benchmark_results.log"
    
    printf "\n"
    printf "  Test: %s\n" "${name}"
    printf "    Description: %s\n" "${description}"
    printf "      This test aims to answer the following questions: \n"
    printf "        Does the benchmark script execute successfully?\n"
    printf "        Are the message rates within acceptable thresholds?\n"
    printf "        Does the topic validation work correctly?\n"
    printf "        Are performance metrics properly parsed?\n"
    
    # Test 1: Basic functionality test
    printf "    Running basic benchmark test...\n"
    
    {
        while true; do
            sleep 1
            printf "." >&2
        done
    } &
    dot_pid=$!
    
    # Set environment variables for the test
    export ROS_BENCHMARK_SCENARIO="simulation_test.launch.py"
    export ROS_BENCHMARK_TOPIC="/ego_vehicle/vehicle_state/dynamic"
    export ROS_BENCHMARK_MIN_RATE=15
    export ROS_BENCHMARK_MAX_JITTER=0.05
    export ROS_BENCHMARK_MAX_STD=0.02
    
    # Run the benchmark script
    benchmark_result=$(make run cmd="bash tools/ros_topic_benchmark.sh" 2>&1)
    benchmark_exit_code=$?
    
    kill $dot_pid 2>/dev/null
    wait $dot_pid 2>/dev/null
    
    printf "\n"
    printf "    Parsing benchmark results...\n"
    echo "${benchmark_result}" > "${benchmark_output_file}"
    
    # Check if benchmark script executed
    if [ $benchmark_exit_code -ne 0 ]; then
        # Check for specific failure reasons
        if echo "$benchmark_result" | grep -q "Scenario not found"; then
            status=$(bold $(red "FAILED"))
            message="        Benchmark failed: Scenario file not found
            Check that simulation_test.launch.py exists in adore_scenarios/simulation_scenarios/
            Output: $(echo "$benchmark_result" | tail -5 | tr '\n' ' ')"
        elif echo "$benchmark_result" | grep -q "does not appear to be published yet"; then
            status=$(bold $(red "FAILED"))
            message="        Benchmark failed: Topic not being published
            The scenario may not be generating the expected topic
            Topic: $ROS_BENCHMARK_TOPIC"
        elif echo "$benchmark_result" | grep -q "BENCHMARK FAILED"; then
            # Parse performance metrics from output
            avg_rate=$(echo "$benchmark_result" | grep "Average Rate:" | awk '{print $3}' | head -1)
            jitter=$(echo "$benchmark_result" | grep "Jitter:" | awk '{print $2}' | sed 's/s$//' | head -1)
            std_dev=$(echo "$benchmark_result" | grep "Std Dev:" | awk '{print $3}' | sed 's/s$//' | head -1)
            
            status=$(bold $(red "FAILED"))
            message="        Benchmark failed: Performance criteria not met
            Average Rate: ${avg_rate:-N/A} Hz (min required: $ROS_BENCHMARK_MIN_RATE Hz)
            Jitter: ${jitter:-N/A}s (max allowed: $ROS_BENCHMARK_MAX_JITTER s)
            Std Dev: ${std_dev:-N/A}s (max allowed: $ROS_BENCHMARK_MAX_STD s)"
            
            # Add specific failure reasons
            if echo "$benchmark_result" | grep -q "Average rate.*below minimum"; then
                message="${message}
            ❌ Rate too low"
            fi
            if echo "$benchmark_result" | grep -q "Jitter.*exceeds maximum"; then
                message="${message}
            ❌ Jitter too high"
            fi
            if echo "$benchmark_result" | grep -q "Standard deviation.*exceeds maximum"; then
                message="${message}
            ❌ Standard deviation too high"
            fi
        else
            status=$(bold $(red "FAILED"))
            message="        Benchmark failed with unexpected error
            Exit code: $benchmark_exit_code
            Last output: $(echo "$benchmark_result" | tail -3 | tr '\n' ' ')"
        fi
    else
        # Success case - parse and display metrics
        avg_rate=$(echo "$benchmark_result" | grep "Average Rate:" | awk '{print $3}' | head -1)
        min_time=$(echo "$benchmark_result" | grep "Min Time:" | awk '{print $3}' | sed 's/s$//' | head -1)
        max_time=$(echo "$benchmark_result" | grep "Max Time:" | awk '{print $3}' | sed 's/s$//' | head -1)
        jitter=$(echo "$benchmark_result" | grep "Jitter:" | awk '{print $2}' | sed 's/s$//' | head -1)
        std_dev=$(echo "$benchmark_result" | grep "Std Dev:" | awk '{print $3}' | sed 's/s$//' | head -1)
        
        status=$(bold $(green "PASSED"))
        message="        Benchmark Performance Metrics:
            Average Rate: ${avg_rate:-N/A} Hz (✓ >= $ROS_BENCHMARK_MIN_RATE Hz)
            Min Time: ${min_time:-N/A}s
            Max Time: ${max_time:-N/A}s
            Jitter: ${jitter:-N/A}s (✓ <= $ROS_BENCHMARK_MAX_JITTER s)
            Std Dev: ${std_dev:-N/A}s (✓ <= $ROS_BENCHMARK_MAX_STD s)
            Topic: $ROS_BENCHMARK_TOPIC
            Scenario: $ROS_BENCHMARK_SCENARIO"
        
        # Additional validation checks
        if echo "$benchmark_result" | grep -q "All performance criteria met successfully"; then
            message="${message}
            ✅ All performance criteria validated successfully"
        fi
    fi
    
    printf "    Message:\n%s\n" "$message"
    printf "    %-77s %s\n" "Status:" "${status}"
    printf "    See the benchmark log for more info: %s\n" "$benchmark_output_file"
    
    # Test 2: Environment variable validation test
    printf "\n    Running environment variable validation test...\n"
    
    # Test with missing scenario
    unset ROS_BENCHMARK_SCENARIO
    validation_result=$(make run cmd="bash tools/ros_topic_benchmark.sh" 2>&1 || true)
    
    if echo "$validation_result" | grep -q "ROS_BENCHMARK_SCENARIO environment variable is required"; then
        printf "    ✅ Environment variable validation: PASSED\n"
    else
        printf "    ❌ Environment variable validation: FAILED\n"
        printf "        Expected error message about missing ROS_BENCHMARK_SCENARIO\n"
    fi
    
    # Test 3: Invalid scenario test
    printf "    Running invalid scenario test...\n"
    
    export ROS_BENCHMARK_SCENARIO="nonexistent_scenario.launch.py"
    invalid_scenario_result=$(make run cmd="bash tools/ros_topic_benchmark.sh" 2>&1 || true)
    
    if echo "$invalid_scenario_result" | grep -q "Scenario not found"; then
        printf "    ✅ Invalid scenario handling: PASSED\n"
    else
        printf "    ❌ Invalid scenario handling: FAILED\n"
        printf "        Expected error message about scenario not found\n"
    fi
    
    # Clean up environment variables
    unset ROS_BENCHMARK_SCENARIO
    unset ROS_BENCHMARK_TOPIC
    unset ROS_BENCHMARK_MIN_RATE
    unset ROS_BENCHMARK_MAX_JITTER
    unset ROS_BENCHMARK_MAX_STD
    
    exit $benchmark_exit_code
}

